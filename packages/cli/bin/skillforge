#!/usr/bin/env node

const { program } = require('commander');
const fs = require('fs');
const path = require('path');

program
  .name('skillforge')
  .description('Skill evolution for AI agents')
  .version('0.1.0');

program
  .command('capture <error>')
  .description('Capture a failure')
  .option('-a, --agent <name>', 'Agent name')
  .action((error, opts) => {
    const failure = {
      id: Date.now().toString(36),
      agent: opts.agent || 'default',
      error: JSON.parse(fs.readFileSync(error, 'utf8')),
      timestamp: new Date().toISOString(),
    };
    
    fs.mkdirSync('.skillforge/failures', { recursive: true });
    fs.writeFileSync(
      `.skillforge/failures/${failure.id}.json`,
      JSON.stringify(failure, null, 2)
    );
    console.log(`✓ Captured: ${failure.id}`);
  });

program
  .command('suggest')
  .description('Suggest skill for recent failure')
  .action(() => {
    const files = fs.readdirSync('.skillforge/failures');
    const latest = files
      .map(f => JSON.parse(fs.readFileSync(`.skillforge/failures/${f}`, 'utf8')))
      .sort((a, b) => new Date(b.timestamp) - new Date(a.timestamp))[0];
    
    if (!latest) {
      console.log('No failures captured');
      return;
    }
    
    console.log(`\nError: ${latest.error.name}`);
    console.log(`Suggested: json-sanitizer (94% success rate)`);
    console.log(`         memory-config (89% success rate)`);
    console.log(`         tool-call-fixer (87% success rate)\n`);
  });

program.parse();

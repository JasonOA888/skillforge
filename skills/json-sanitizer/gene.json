{
  "id": "skill_json_sanitizer_v321",
  "name": "json-sanitizer",
  "version": "3.2.1",
  "description": "Sanitize JSON strings with control characters",
  "gene": {
    "trigger": {
      "patterns": [
        "JSONDecodeError.*control character",
        "Expecting.*got.*control"
      ],
      "error_types": ["JSONDecodeError"],
      "context_requirements": ["json_string"]
    },
    "strategy": [
      {
        "step": "detect_control_chars",
        "action": "Scan input for unescaped control characters",
        "implementation": "re.search(r'(?<!\\\\)[\\\\x00-\\\\x1f]', input)"
      },
      {
        "step": "escape_chars",
        "action": "Replace control chars with escaped versions",
        "implementation": "re.sub(pattern, escape_map[char], input)"
      },
      {
        "step": "validate_json",
        "action": "Attempt json.loads() on sanitized string",
        "implementation": "json.loads(sanitized_string)"
      },
      {
        "step": "return_result",
        "action": "Return parsed JSON object",
        "optimization": "Cache sanitized string for repeated inputs"
      }
    ],
    "context_awareness": {
      "language": "python",
      "frameworks": ["langchain", "openclaw", "crewai"],
      "dependencies": ["json", "re"]
    }
  },
  "metadata": {
    "success_rate": 0.942,
    "uses": 12847,
    "token_efficiency": 0.12,
    "contributors": ["evolution-engine"],
    "tags": ["json", "parsing", "error-handling", "control-characters"],
    "source_issues": [
      "MoonshotAI/kimi-cli#1378",
      "langchain-ai/langchain#8471"
    ],
    "created_at": "2026-03-12T00:00:00Z",
    "updated_at": "2026-03-12T00:00:00Z"
  }
}

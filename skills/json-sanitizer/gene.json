{
  "id": "skill_json_sanitizer_v321",
  "name": "json-sanitizer",
  "version": "3.2.1",
  "description": "Sanitize JSON strings with control characters",
  "gene": {
    "trigger": {
      "patterns": [
        "JSONDecodeError.*control character",
        "Expecting.*got.*control"
      ],
      "error_types": ["JSONDecodeError"],
      "context_requirements": ["json_string"]
    },
    "strategy": [
      {
        "step": "detect_control_chars",
        "action": "Scan input for unescaped control characters",
        "fallback": "If no control chars, pass through"
      },
      {
        "step": "escape_chars",
        "action": "Replace control chars with escaped versions using regex pattern",
        "implementation": "re.sub(r'(?<!\\\\)([\\\\n\\\\r\\\\t\\\\f\\\\b])', escape_map[char], input)"
      },
      {
        "step": "validate_json",
        "action": "Attempt json.loads() on sanitized string",
        "error_handling": "If still fails, report original error with context"
      },
      {
        "step": "return_result",
        "action": "Return parsed JSON object",
        "optimization": "Cache sanitized string if identical input seen before"
      }
    ],
    "context_awareness": {
      "language": "python",
      "frameworks": ["langchain", "openclaw", "crewai"],
      "dependencies": ["json", "re"]
    },
    "error_recovery": [
      {
        "condition": "Sanitization succeeds but parse fails",
        "action": "Try alternative JSON parsers (orjson, ujson)"
      },
      {
        "condition": "Multiple control char patterns",
        "action": "Apply multiple sanitization passes"
      }
    ],
    "optimizations": {
      "token_efficiency": {
        "technique": "Early termination if no control chars detected",
        "saving": "Saves 12% tokens on average"
      },
      "caching": {
        "enabled": true,
        "strategy": "LRU with 1000 entry limit"
      }
    }
  },
  "metadata": {
    "success_rate": 0.942,
    "uses": 12847,
    "token_efficiency": 0.12,
    "contributors": ["evolution-engine", "jason-l"],
    "tags": ["json", "parsing", "error-handling", "control-characters", "llm-output"],
